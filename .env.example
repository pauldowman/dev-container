# One or more SSH public keys to authorize for login (newline-separated)
# SSH_AUTHORIZED_KEYS="ssh-ed25519 AAAA... user@host"

# Username inside the container (defaults to your local $USER)
# SSH_USERNAME=myusername

# Hostname of the remote machine running the container (used as a jump host)
# REMOTE_DEV_SERVER=my-dev-box

# Ports to forward from inside the container to your local machine (comma-separated)
# FORWARD_PORTS=8000,3000

# Dockerfile to use for building the container (defaults to Dockerfile)
# Use Dockerfile.gui for XFCE4 desktop + xrdp GUI access
# DOCKERFILE=Dockerfile.gui
