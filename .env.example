# =============================================================================
# BUILD variables (docker build args — require ./build to take effect)
# =============================================================================

# Username inside the container (defaults to your local $USER)
# USERNAME=myusername

# Git repo URL to clone and install as dotfiles (optional)
# DOTFILES_REPO=https://github.com/yourname/dotfiles.git

# Command to run inside the cloned dotfiles directory (defaults to ./install.sh)
# DOTFILES_INSTALL_CMD=./install.sh

# Dockerfile to use for building the container (defaults to Dockerfile)
# Use Dockerfile.gui for XFCE4 desktop + xrdp GUI access
# DOCKERFILE=Dockerfile.gui


# =============================================================================
# RUN variables (docker compose — require `docker compose up` or ./start to take effect)
# =============================================================================

# One or more SSH public keys to authorize for login (newline-separated)
# SSH_AUTHORIZED_KEYS="ssh-ed25519 AAAA... user@host"

# Absolute path to code directory — mounted at the same path inside and outside the container.
# This ensures Docker volume mounts from inside the container resolve correctly on the host.
# CODE_DIR=/Users/myusername/code

# Timezone inside the container (optional; host /etc/localtime is also mounted)
# TZ=America/New_York


# =============================================================================
# CONNECT variables (used by the ./dev script when SSHing into the container)
# =============================================================================

# Ports to forward from inside the container to your local machine (comma-separated)
# FORWARD_PORTS=8000,3000

