#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# shellcheck source=/dev/null
source "$SCRIPT_DIR/scripts/env.sh"
load_env_file "$SCRIPT_DIR/.env"

INSTANCE="${DEV_CONTAINER_INSTANCE:-dev-container}"
SSH_PORT="${SSH_PORT:-}"
SSH_PORT_ARG=""

usage() {
  echo "Usage: start [--instance <name>] [--ssh-port <port>]" >&2
}

validate_instance() {
  if [[ ! "$INSTANCE" =~ ^[a-z0-9][a-z0-9_-]*$ ]]; then
    echo "Error: instance must start with a lowercase letter or digit and contain only lowercase letters, digits, underscores, or hyphens" >&2
    exit 1
  fi
}

validate_port() {
  if [[ -n "$SSH_PORT" && ! "$SSH_PORT" =~ ^[0-9]+$ ]]; then
    echo "Error: SSH port must be numeric" >&2
    exit 1
  fi
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --instance)
      if [[ -z "${2:-}" ]]; then
        usage
        exit 1
      fi
      INSTANCE="$2"
      shift 2
      ;;
    --ssh-port)
      if [[ -z "${2:-}" ]]; then
        usage
        exit 1
      fi
      SSH_PORT_ARG="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      usage
      exit 1
      ;;
  esac
done

validate_instance
load_env_file "$SCRIPT_DIR/.env.$INSTANCE"

if [[ -n "$SSH_PORT_ARG" ]]; then
  SSH_PORT="$SSH_PORT_ARG"
else
  SSH_PORT="${SSH_PORT:-}"
fi

validate_port

cd "${SCRIPT_DIR}"

container_id="$(env INSTANCE="$INSTANCE" SSH_PORT="$SSH_PORT" docker compose -p "$INSTANCE" ps -q dev-container 2>/dev/null || true)"
if [[ -z "$container_id" || "$(docker inspect -f '{{.State.Running}}' "$container_id" 2>/dev/null || true)" != "true" ]]; then
  echo "Starting $INSTANCE..."
  export DOCKER_CLI_HINTS=false
  env INSTANCE="$INSTANCE" SSH_PORT="$SSH_PORT" docker compose -p "$INSTANCE" up -d
fi
