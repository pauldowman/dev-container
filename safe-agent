#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Parse tool argument (default: claude)
tool="${1:-claude}"
shift || true
case "$tool" in
claude) cmd='~/.local/bin/claude' ;;
codex) cmd='/usr/local/bin/codex' ;;
shell) cmd='zsh' ;;
*)
  echo "Usage: $0 [claude|codex|shell] [args...]" >&2
  exit 1
  ;;
esac

path=$(pwd)

# Only allocate a TTY when stdin is a terminal (not in git hooks, CI, etc.)
tty_flag=""
[ -t 0 ] && tty_flag="-t"

export DOCKER_CLI_HINTS=false
docker run -i $tty_flag \
  -w "$path" \
  -v "${HOME}/code:${HOME}/code" \
  -v "${HOME}/.claude:/home/${USER}/.claude" \
  -v "${HOME}/.claude.json:/home/${USER}/.claude.json" \
  -v "${HOME}/.codex:/home/${USER}/.codex" \
  -v "${SCRIPT_DIR}/data/certs:/usr/local/share/ca-certificates/extra:ro" \
  -v "/run/host-services/ssh-auth.sock:/run/host-services/ssh-auth.sock" \
  -v "${HOME}/.ssh/id_signing.pub:/home/${USER}/.ssh/id_signing.pub:ro" \
  -e "SSH_AUTH_SOCK=/run/host-services/ssh-auth.sock" \
  -e "GH_TOKEN=$(gh auth token)" \
  dev-agent zsh -l -i -c "$cmd \"\$@\"" -- "$@"
