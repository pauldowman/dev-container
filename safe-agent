#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Parse tool argument (default: claude)
tool="${1:-claude}"
shift || true
case "$tool" in
claude) cmd='~/.local/bin/claude' ;;
codex) cmd='/usr/local/bin/codex' ;;
shell) cmd='zsh' ;;
*)
  echo "Usage: $0 [claude|codex|shell] [args...]" >&2
  exit 1
  ;;
esac

# Start container if not running
if ! docker ps --format '{{.Names}}' | grep -q '^dev-agent$'; then
  echo "Starting dev-agent container..."
  docker compose -f "$SCRIPT_DIR/docker-compose.yml" up -d --build
fi

path=$(pwd)

# Only allocate a TTY when stdin is a terminal (not in git hooks, CI, etc.)
tty_flag=""
[ -t 0 ] && tty_flag="-t"

export DOCKER_CLI_HINTS=false
docker exec -i $tty_flag \
  -w "$path" \
  -e "GH_TOKEN=$(gh auth token)" \
  dev-agent zsh -l -i -c "$cmd \"\$@\"" -- "$@"
