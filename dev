#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

case "${1:-}" in
  --init)
    cat <<'EOF'
_dev() {
  _alternative \
    'args:subcommand:(list)' \
    'dirs:directory:_path_files -/ -W $HOME/code'
}
compdef _dev dev
EOF
    exit 0
    ;;
  "")
    echo "Usage: dev <session-name> | dev list" >&2
    exit 1
    ;;
esac

if [ -z "${SSH_AUTH_SOCK:-}" ]; then
  eval "$(ssh-agent -s)" >/dev/null
fi

ssh_opts=(-A -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR -o "SetEnv TERM=xterm-256color COLORTERM=truecolor" -p 2222)
if [ -n "${REMOTE_DEV_SERVER:-}" ]; then
  ssh_opts+=(-J "$REMOTE_DEV_SERVER")
fi

case "$1" in
  list)
    ssh "${ssh_opts[@]}" localhost tmux list-sessions
    ;;
  *)
    session_name="${1//\//-}"
    ssh "${ssh_opts[@]}" -t localhost \
      GH_TOKEN="$(gh auth token)" \
      tmux new-session -A -s "$session_name" -c "\$HOME/code/$1"
    ;;
esac
