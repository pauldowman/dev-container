#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

case "${1:-}" in
  --init)
    cat <<'EOF'
_dev() {
  _alternative \
    'args:subcommand:(list)' \
    'dirs:directory:_path_files -/ -W $HOME/code'
}
compdef _dev dev
EOF
    exit 0
    ;;
  "")
    echo "Usage: dev <session-name> | dev list" >&2
    exit 1
    ;;
esac

ssh-add "${HOME}/.ssh/id_signing" >/dev/null 2>&1 || true

# Start container if not running
if ! docker ps --format '{{.Names}}' | grep -q '^dev-container$'; then
  echo "Starting dev-container container..."
  docker compose -f "$SCRIPT_DIR/docker-compose.yml" up -d
fi

# Only allocate a TTY when stdin is a terminal (not in git hooks, CI, etc.)
tty_flag=""
[ -t 0 ] && tty_flag="-t"

export DOCKER_CLI_HINTS=false

case "$1" in
  list)
    docker exec -i $tty_flag dev-container tmux list-sessions
    ;;
  *)
    session_name="${1//\//-}"
    docker exec -i $tty_flag \
      -e "GH_TOKEN=$(gh auth token)" \
      dev-container tmux new-session -A -s "$session_name" -c "/workspace/code/$1"
    ;;
esac
