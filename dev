#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

case "${1:-}" in
  --init)
    shell="${2:-${SHELL:-}}"
    shell="${shell##*/}"
    if [ -f "$SCRIPT_DIR/.env" ]; then
      # shellcheck source=/dev/null
      source "$SCRIPT_DIR/.env"
    fi
    if [ -z "${CODE_DIR:-}" ]; then
      echo "Error: CODE_DIR must be set in .env" >&2
      exit 1
    fi
    code_dir="$CODE_DIR"
    case "$shell" in
      fish)
        cat <<EOF
function __dev_complete_dirs
  set -l token (commandline -ct)
  set -l code_dir "$code_dir"
  set -l prefix ""
  set -l search_dir "\$code_dir"

  if string match -q "*/*" -- "\$token"
    set prefix (string replace -r '[^/]*$' '' -- "\$token")
    set search_dir "\$code_dir/\$prefix"
  end

  if test -d "\$search_dir"
    for path in "\$search_dir"*/
      test -d "\$path"; or continue
      printf "%s%s/\n" "\$prefix" (basename "\$path")
    end
  end
end

complete -c dev -f
complete -c dev -n 'not __fish_seen_subcommand_from list' -a list -d 'List active tmux sessions'
complete -c dev -n 'not __fish_seen_subcommand_from list' -a '(__dev_complete_dirs)'
EOF
        ;;
      zsh|"")
        cat <<EOF
_dev() {
  _alternative \\
    'args:subcommand:(list)' \\
    'dirs:directory:_path_files -/ -W ${code_dir}'
}
compdef _dev dev
EOF
        ;;
      *)
        echo "Error: unsupported shell for --init: $shell" >&2
        echo "Supported shells: zsh, fish" >&2
        exit 1
        ;;
    esac
    exit 0
    ;;
  "")
    echo "Usage: dev <session-name> | dev list" >&2
    exit 1
    ;;
esac

if [ -f "$SCRIPT_DIR/.env" ]; then
  # shellcheck source=/dev/null
  source "$SCRIPT_DIR/.env"
fi

if [ -z "${CODE_DIR:-}" ]; then
  echo "Error: CODE_DIR must be set in .env" >&2
  exit 1
fi

if [ -z "${SSH_AUTH_SOCK:-}" ]; then
  eval "$(ssh-agent -s)" >/dev/null
  ssh-add
fi

ssh_opts=(-A -l "${USERNAME:-$USER}" -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR -o "SetEnv TERM=xterm-256color COLORTERM=truecolor" -p 2222)
session_ssh_opts=("${ssh_opts[@]}")
if [ -n "${FORWARD_PORTS:-}" ]; then
  IFS=',' read -ra ports <<< "$FORWARD_PORTS"
  for port in "${ports[@]}"; do
    session_ssh_opts+=(-L "${port}:localhost:${port}")
  done
fi

case "$1" in
  list)
    ssh "${ssh_opts[@]}" localhost tmux list-sessions
    ;;
  *)
    echo "Connecting to ${USERNAME:-$USER}@localhost..."
    session_name="${1//\//-}"
    ssh "${session_ssh_opts[@]}" -t localhost \
      GH_TOKEN="$(gh auth token)" \
      tmux new-session -A -s "$session_name" -c "$CODE_DIR/$1"
    ;;
esac
