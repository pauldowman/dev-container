#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

case "${1:-}" in
  --init)
    cat <<'EOF'
_dev() {
  _alternative \
    'args:subcommand:(list)' \
    'dirs:directory:_path_files -/ -W $HOME/code'
}
compdef _dev dev
EOF
    exit 0
    ;;
  "")
    echo "Usage: dev <session-name> | dev list" >&2
    exit 1
    ;;
esac

ssh-add "${HOME}/.ssh/id_signing" >/dev/null 2>&1 || true

# Start container if not running
if ! docker ps --format '{{.Names}}' | grep -q '^dev-container$'; then
  echo "Starting dev-container container..."
  export DOCKER_CLI_HINTS=false
  docker compose -f "$SCRIPT_DIR/docker-compose.yml" up -d
fi

ssh_opts=(-A -i "${HOME}/.ssh/id_signing" -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o SetEnv=TERM=xterm-256color -p 2222)

case "$1" in
  list)
    ssh "${ssh_opts[@]}" localhost tmux list-sessions
    ;;
  *)
    session_name="${1//\//-}"
    ssh "${ssh_opts[@]}" -t localhost \
      GH_TOKEN="$(gh auth token)" \
      tmux new-session -A -s "$session_name" -c "$HOME/code/$1"
    ;;
esac
